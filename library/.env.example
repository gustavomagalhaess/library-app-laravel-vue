APP_NAME=Library
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080
# IMPORTANT — Dusk runs `php artisan dusk` inside the `app` (PHP-FPM)
# container. The browser launched by Chromium also lives inside that
# container, so the URL it visits must resolve on the container's
# network — NOT on the host.
#
# `localhost:8080` is bound on the host machine (and on the `web` nginx
# container), but inside `app` nothing listens on 8080, so the browser
# gets ERR_CONNECTION_REFUSED. The `web` service is reachable across the
# docker-compose `library-net` bridge at http://web (port 80).
#APP_URL=http://web
APP_TIMEZONE=UTC

LOG_CHANNEL=stack
LOG_LEVEL=debug

# DB — points at the Docker compose `db` service.
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=library
# Reuse the running MySQL container — Dusk needs persistent state
# across the HTTP requests it issues, so an in-memory SQLite won't work
# for tests that exercise authenticated flows. Use a dedicated database
# so a Dusk run doesn't trash dev data.
#DB_DATABASE=library_dusk
DB_USERNAME=library
DB_PASSWORD=secret

# Cache + sessions backed by Redis.
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
QUEUE_CONNECTION=redis
# For Dusk - Sync queue so any job dispatched during a browser test runs inline
# instead of waiting for the Horizon worker.
# QUEUE_CONNECTION=sync

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

# Mail — pipe to log so seed-created accounts can receive verify mails locally.
MAIL_MAILER=log

FILESYSTEM_DISK=local

# Vite
VITE_APP_NAME="${APP_NAME}"

# Fortify defaults — adjust if you disable any feature in config/fortify.php
FORTIFY_USERNAME=email

# For Dusk - Browser binary + driver are installed in docker/php/Dockerfile.
CHROME_BIN=/usr/bin/chromium-browser
DUSK_DRIVER_URL=http://localhost:9515
