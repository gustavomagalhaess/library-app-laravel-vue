APP_NAME=Library
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_TIMEZONE=UTC

LOG_CHANNEL=stack
LOG_LEVEL=debug

# DB — points at the Docker compose `db` service.
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=library
DB_USERNAME=library
DB_PASSWORD=secret

# Cache + sessions backed by Redis.
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
QUEUE_CONNECTION=redis

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

# Mail — pipe to log so seed-created accounts can receive verify mails locally.
MAIL_MAILER=log

FILESYSTEM_DISK=local

# Vite
VITE_APP_NAME="${APP_NAME}"

# Fortify defaults — adjust if you disable any feature in config/fortify.php
FORTIFY_USERNAME=email
