# Host-side variables consumed by docker-compose.yml.
# These are NOT the Laravel .env — that one lives at library/.env after install.

APP_UID=1000
APP_GID=1000

APP_PORT=8080
VITE_PORT=5173

DB_PORT=3306
DB_DATABASE=library
DB_USERNAME=library
DB_PASSWORD=secret
DB_ROOT_PASSWORD=root

REDIS_PORT=6379

XDEBUG_MODE=

CHROME_HEADLESS=