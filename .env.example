# Host-side variables consumed by docker-compose.yml.
# These are NOT the Laravel .env — that one lives at library/.env after install.

APP_UID=1000
APP_GID=1000

APP_PORT=8080
VITE_PORT=5173

DB_PORT=3306
DB_DATABASE=library
DB_USERNAME=library
DB_PASSWORD=secret
DB_ROOT_PASSWORD=root

REDIS_PORT=6379

XDEBUG_MODE=

CHROME_HEADLESS=

# === AIOX Variables (added 2026-05-22) ===
# Cost: ~$0.14/M tokens with tool calling support
DEEPSEEK_API_KEY=
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=
# OpenAI API Key - Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Get your key at: https://exa.ai/
EXA_API_KEY=
# Usually free, no key required for basic usage
CONTEXT7_API_KEY=
# Get from your Supabase project settings
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=
# Get from: ClickUp Settings > Apps > API Token
CLICKUP_API_KEY=
# From your N8N instance settings
N8N_API_KEY=
N8N_WEBHOOK_URL=
# Sentry (error tracking)
SENTRY_DSN=
# Railway (deployment)
RAILWAY_TOKEN=
# Vercel (deployment)
VERCEL_TOKEN=
# --------------------------------------------
NODE_ENV=development
AIOX_VERSION=5.2.9
